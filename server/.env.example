# ============ App ============
APP_ENV=dev
APP_DEBUG=true
APP_NAME=DiaryAI-PersonalHub
APP_VERSION=0.1.0

# ============ Server ============
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
# true = 任意前端域名可访问（仅测试）；false = 仅 CORS_ORIGINS 白名单（可带 Cookie）
CORS_ALLOW_ALL=true
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ============ Database ============
# 本地直接装 PostgreSQL：用 localhost；Docker 部署时再改成 postgres
DATABASE_URL=postgresql+psycopg://diary:diary@localhost:5432/diary

# ============ Redis（可选，本地开发不装也能跑） ============
REDIS_URL=redis://localhost:6379/0
# 没装 Redis 就把下面这一行设为 false，LLM 缓存会自动变成空操作
LLM_CACHE_ENABLED=false

# ============ JWT ============
JWT_SECRET=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MIN=60
JWT_REFRESH_EXPIRE_DAYS=14

# ============ LLM ============
LLM_PROVIDER=deepseek
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_TIMEOUT_S=60

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

OLLAMA_BASE_URL=http://localhost:11434
